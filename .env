
PORN_URL=https://your-server.vercel.app
API_KEY_PROD=your-secret-token-here

# Your phone number (digits only, with country code)
PHONE_NUMBER=254712345678

# Owner number (digits only — bypasses private mode always)
OWNER_NUMBER=254712345678
OWNER_NAME=XTR Owner
BOT_NAME=Buddy-XTR
PREFIX=.

# ── ACCESS MODE ───────────────────────────────────────────
# Owner ALWAYS bypasses private mode regardless of this setting
PRIVATE_MODE=false

# Buddy-XTR AUTOMATED FEATURES
AUTO_VIEW_STATUS=true
AUTO_LIKE_STATUS=true
AUTO_REACT=false
AUTO_REACT_OUTGOING=false
AUTO_REPLY=true

# ── ANTI FEATURES ─────────────────────────────────────────
ANTI_DELETE=false
ANTI_DELETE_SCOPE=all
ANTI_CALL=false
ANTI_CALL_ACTION=reject
